# ================================================================
# CONNECTHUB - API ENDPOINTS (PRODUCTION)
# ================================================================

# Auth Service (Login, Register, Google Auth)
REACT_APP_API_BASE_URL=https://connecthub-auth.onrender.com
REACT_APP_AUTH_URL=https://connecthub-auth.onrender.com

# Messaging Service (Chats, Messages)
REACT_APP_MESSAGING_URL=https://connecthub-messaging.onrender.com

# Room Service (Rooms, Groups)
REACT_APP_ROOM_URL=https://connecthub-room.onrender.com

# Media Service (File Uploads)
REACT_APP_MEDIA_URL=https://connecthub-media.onrender.com

# Presence Service (Online Status)
REACT_APP_PRESENCE_URL=https://connecthub-presence.onrender.com

# Notification Service (Notifications)
REACT_APP_NOTIFICATION_URL=https://connecthub-notification.onrender.com

# Admin Service
REACT_APP_ADMIN_URL=https://connecthub-admin.onrender.com

# Gateway Service
REACT_APP_GATEWAY_URL=https://connecthub-gateway.onrender.com

# ================================================================
# SIGNALR HUBS (Real-time)
# ================================================================

# Presence Hub (Online Status)
REACT_APP_SIGNALR_PRESENCE_URL=https://connecthub-presence.onrender.com/presenceHub

# Notification Hub (Real-time Notifications)
REACT_APP_SIGNALR_NOTIFICATION_URL=https://connecthub-notification.onrender.com/notificationHub

# ================================================================
# FEATURE FLAGS
# ================================================================

REACT_APP_ENABLE_GOOGLE_AUTH=true