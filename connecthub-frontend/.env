# ================================================================
# CONNECTHUB - API ENDPOINTS
# ================================================================

# Auth Service (Login, Register, Google Auth)
REACT_APP_API_BASE_URL=http://localhost:5046
REACT_APP_AUTH_URL=http://localhost:5046

# Messaging Service (Chats, Messages)
REACT_APP_MESSAGING_URL=http://localhost:5289

# Room Service (Rooms, Groups)
REACT_APP_ROOM_URL=http://localhost:5283

# Media Service (File Uploads)
REACT_APP_MEDIA_URL=http://localhost:5290

# ================================================================
# SIGNALR HUBS (Real-time)
# ================================================================

# Presence Hub (Online Status)
REACT_APP_SIGNALR_PRESENCE_URL=http://localhost:5289/presenceHub

# Notification Hub (Real-time Notifications)
REACT_APP_SIGNALR_NOTIFICATION_URL=http://localhost:5289/notificationHub

# ================================================================
# FEATURE FLAGS
# ================================================================

REACT_APP_ENABLE_GOOGLE_AUTH=true